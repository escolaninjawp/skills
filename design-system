### Model вҖ” padrГЈo obrigatГіrio

```python
from django.db import models
from django.utils.translation import gettext_lazy as _


class MeuModelo(models.Model):
    class Status(models.TextChoices):
        ATIVO = "ativo", _("Ativo")
        INATIVO = "inativo", _("Inativo")
        PENDENTE = "pendente", _("Pendente")

    nome = models.CharField(_("nome"), max_length=255)
    status = models.CharField(
        _("status"),
        max_length=20,
        choices=Status.choices,
        default=Status.PENDENTE,
    )
    criado_em = models.DateTimeField(_("criado em"), auto_now_add=True)
    atualizado_em = models.DateTimeField(_("atualizado em"), auto_now=True)

    class Meta:
        verbose_name = _("Meu Modelo")
        verbose_name_plural = _("Meus Modelos")
        ordering = ["-criado_em"]

    def __str__(self) -> str:
        return self.nome
```

### ModelAdmin вҖ” padrГЈo Unfold

```python
from django.contrib import admin
from unfold.admin import ModelAdmin
from unfold.decorators import display, action


@admin.register(MeuModelo)
class MeuModeloAdmin(ModelAdmin):
    list_display = ["nome", "status_badge", "criado_em"]
    list_filter = ["status"]
    search_fields = ["nome"]
    list_fullwidth = True
    list_filter_submit = True

    fieldsets = [
        ("InformaГ§Гөes BГЎsicas", {
            "fields": ["nome", "descricao"],
        }),
        ("ConfiguraГ§Гөes", {
            "fields": ["status", "ativo"],
            "classes": ["collapse"],
        }),
    ]

    actions = ["ativar_selecionados", "desativar_selecionados"]

    @display(description="Status", label=True)
    def status_badge(self, obj):
        return obj.status

    @action(description="Ativar selecionados")
    def ativar_selecionados(self, request, queryset):
        queryset.update(status=MeuModelo.Status.ATIVO)

    @action(description="Desativar selecionados")
    def desativar_selecionados(self, request, queryset):
        queryset.update(status=MeuModelo.Status.INATIVO)
```

### Services вҖ” lГіgica de negГіcio fora das views

```python
# services.py
from django.db import transaction
from .models import MeuModelo


class MeuModeloService:
    @staticmethod
    @transaction.atomic
    def criar(dados: dict) -> MeuModelo:
        # validaГ§Гөes e regras de negГіcio aqui
        return MeuModelo.objects.create(**dados)

    @staticmethod
    def buscar_ativos():
        return MeuModelo.objects.filter(status=MeuModelo.Status.ATIVO).select_related()
```

