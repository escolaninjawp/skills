## 2. Serviço de Geração IA (`apps/community/services/generator.py`)

```python
import json
import random
import re
from datetime import date, timedelta

from django.utils import timezone

from apps.community.models import CommunityConfig, CommunityCategory, CommunityQuestion, CommunityAnswer


def _get_openai_client(api_key: str):
    from openai import OpenAI
    return OpenAI(api_key=api_key)


def _resolve_api_key(config) -> str:
    """Busca a chave OpenAI: config > tenant vitoria-demo > settings."""
    key = config.openai_api_key
    if not key:
        try:
            from apps.tenants.models import TenantSettings
            ts = TenantSettings.objects.filter(tenant__slug='vitoria-demo').first()
            if ts and ts.openai_api_key:
                key = ts.openai_api_key
        except Exception:
            pass
    if not key:
        from django.conf import settings as ds
        key = getattr(ds, 'OPENAI_API_KEY', '')
    return key


def _distribute_questions(categories, total: int) -> list[tuple]:
    """Distribui perguntas pelas categorias priorizando as com menos conteúdo."""
    cats = list(categories)
    if not cats:
        return []
    counts = {c.pk: CommunityQuestion.objects.filter(category=c, is_published=True).count() for c in cats}
    cats.sort(key=lambda c: counts[c.pk])
    distribution = []
    for i, cat in enumerate(cats):
        n = total // len(cats) + (1 if i < total % len(cats) else 0)
        if n > 0:
            distribution.append((cat, n))
    return distribution


def _ask_question(client, model: str, category, existing_titles: list[str]) -> dict:
    existing = '\n'.join(f'- {t}' for t in existing_titles[-20:]) if existing_titles else 'Nenhuma ainda.'
    prompt = f"""Você é especialista em SEO e conteúdo para o mercado brasileiro de joias, semi-joias e galvânica.

Gere UMA pergunta realista de fórum feita por um profissional brasileiro (joalheiro, revendedor, galvanicador ou empreendedor) sobre a categoria: **{category.name}**

Categoria descrição: {category.description}

Perguntas já existentes (evite repetir):
{existing}

REGRAS:
- Título entre 40-100 caracteres, tom natural como pergunta real de fórum
- Corpo: 1-2 parágrafos de contexto explicando o problema/situação
- seo_title: versão SEO do título (max 60 chars), inclua palavras-chave
- seo_description: resumo para Google (max 160 chars)
- author_name: nome brasileiro completo realista (ex: "Maria Santos", "Carlos Oliveira")
- author_avatar: apenas o PRIMEIRO NOME em minúsculas sem acento (ex: "maria", "carlos") — usado como seed do avatar

Responda SOMENTE com JSON válido:
{{
  "title": "...",
  "body": "...",
  "seo_title": "...",
  "seo_description": "...",
  "author_name": "...",
  "author_avatar": "..."
}}"""

    resp = client.chat.completions.create(
        model=model,
        messages=[{'role': 'user', 'content': prompt}],
        temperature=0.85,
        max_tokens=600,
        response_format={'type': 'json_object'},
    )
    return json.loads(resp.choices[0].message.content)


def _ask_answers(client, model: str, question_title: str, question_body: str,
                 answers_min: int, answers_max: int) -> list[dict]:
    n = random.randint(answers_min, answers_max)
    prompt = f"""Você é moderador de um fórum brasileiro de joias, semi-joias e galvânica.

Gere {n} respostas DIFERENTES para a pergunta abaixo. Cada resposta deve ter uma persona distinta:
- Iniciante curioso (1-2 anos no ramo)
- Experiente veterano (10+ anos)
- Revendedor do interior
- Dona de ateliê/loja
- Galvanicador técnico
- Fornecedor
(use as personas disponíveis variando entre as {n} respostas)

PERGUNTA: {question_title}
CONTEXTO: {question_body}

REGRAS:
- Tom conversacional, como fórum real — não formal demais
- Respostas entre 80-250 palavras cada
- Primeira resposta: is_accepted=true (a melhor resposta)
- Demais: is_accepted=false
- upvotes: número realista entre 0-47
- author_name: nome brasileiro completo realista
- author_avatar: apenas o PRIMEIRO NOME em minúsculas sem acento (ex: "ana", "joao") — seed do avatar
- Datas espalhadas nos últimos 30 dias (apenas inclua no JSON, não precisa de data)

Responda SOMENTE com JSON array válido:
[
  {{
    "author_name": "...",
    "author_avatar": "...",
    "body": "...",
    "upvotes": 0,
    "is_accepted": true,
    "order": 0
  }},
  ...
]"""

    resp = client.chat.completions.create(
        model=model,
        messages=[{'role': 'user', 'content': prompt}],
        temperature=0.9,
        max_tokens=3000,
    )
    raw = resp.choices[0].message.content.strip()
    # extrai array JSON do texto
    match = re.search(r'\[.*\]', raw, re.DOTALL)
    if match:
        raw = match.group(0)
    return json.loads(raw)


def generate_daily_content(count: int = None) -> dict:
    config = CommunityConfig.get_solo()
    if not config.generation_enabled:
        return {'error': 'Geração desativada nas configurações.'}

    api_key = _resolve_api_key(config)
    if not api_key or api_key.startswith('sk-your'):
        return {'error': 'API key OpenAI não configurada.'}

    total = count or config.questions_per_day
    categories = CommunityCategory.objects.filter(is_active=True)
    if not categories.exists():
        return {'error': 'Nenhuma categoria ativa cadastrada.'}

    client = _get_openai_client(api_key)
    model = config.openai_model
    generated, errors = 0, 0
    questions_data = []
    existing_titles = list(
        CommunityQuestion.objects.filter(is_published=True)
        .order_by('-created_at')
        .values_list('title', flat=True)[:50]
    )

    for category, n_questions in _distribute_questions(categories, total):
        for _ in range(n_questions):
            try:
                q_data = _ask_question(client, model, category, existing_titles)
                question = CommunityQuestion.objects.create(
                    category=category,
                    title=q_data['title'],
                    body=q_data.get('body', ''),
                    author_name=q_data.get('author_name', 'Usuário'),
                    author_avatar=q_data.get('author_avatar', 'user'),
                    seo_title=q_data.get('seo_title', '')[:80],
                    seo_description=q_data.get('seo_description', '')[:200],
                )
                existing_titles.append(q_data['title'])

                answers_data = _ask_answers(
                    client, model, question.title, question.body,
                    config.answers_min, config.answers_max,
                )
                answer_objs = []
                for i, a in enumerate(answers_data):
                    answer_objs.append(CommunityAnswer(
                        question=question,
                        body=a.get('body', ''),
                        author_name=a.get('author_name', 'Usuário'),
                        author_avatar=a.get('author_avatar', 'user'),
                        upvotes=min(int(a.get('upvotes', 0)), 999),
                        is_accepted=bool(a.get('is_accepted', False)) if i == 0 else False,
                        order=i,
                    ))
                CommunityAnswer.objects.bulk_create(answer_objs)
                question.answer_count = len(answer_objs)
                question.save(update_fields=['answer_count'])

                generated += 1
                questions_data.append({'title': question.title, 'answers': answers_data})

            except Exception as e:
                errors += 1
                print(f'[community] Erro ao gerar pergunta: {e}')

    config.last_generated_at = timezone.now()
    config.save(update_fields=['last_generated_at'])

    return {'generated': generated, 'errors': errors, 'questions': questions_data}
