## 3. Views (`apps/community/views.py`)

```python
from django.shortcuts import render, get_object_or_404
from django.db.models import F, Count, Q

from .models import CommunityCategory, CommunityQuestion, CommunityAnswer


def community_home(request):
    categories = (
        CommunityCategory.objects
        .filter(is_active=True)
        # IMPORTANTE: usar nome diferente de qualquer @property do model
        .annotate(num_questions=Count('questions', filter=Q(questions__is_published=True)))
        .order_by('order')
    )
    recent_questions = (
        CommunityQuestion.objects.filter(is_published=True)
        .select_related('category')
        .order_by('-created_at')[:20]
    )
    return render(request, 'community/home.html', {
        'categories': categories,
        'recent_questions': recent_questions,
        'total_questions': CommunityQuestion.objects.filter(is_published=True).count(),
        'total_answers': CommunityAnswer.objects.count(),
    })


def community_category(request, cat_slug):
    category = get_object_or_404(CommunityCategory, slug=cat_slug, is_active=True)
    all_qs = CommunityQuestion.objects.filter(category=category, is_published=True).order_by('-created_at')

    per_page = 20
    page = max(1, int(request.GET.get('page', 1)))
    total = all_qs.count()
    total_pages = max(1, (total + per_page - 1) // per_page)
    page = min(page, total_pages)
    questions = all_qs[(page-1)*per_page : page*per_page]

    return render(request, 'community/category.html', {
        'category': category,
        'questions': questions,
        'total': total,
        'page': page,
        'total_pages': total_pages,
        'has_prev': page > 1,
        'has_next': page < total_pages,
        'prev_page': page - 1,
        'next_page': page + 1,
        'other_categories': CommunityCategory.objects.filter(is_active=True).exclude(pk=category.pk).order_by('order'),
    })


def community_question(request, cat_slug, q_slug):
    category = get_object_or_404(CommunityCategory, slug=cat_slug, is_active=True)
    question = get_object_or_404(CommunityQuestion, slug=q_slug, category=category, is_published=True)

    CommunityQuestion.objects.filter(pk=question.pk).update(views=F('views') + 1)
    question.views += 1

    answers = list(question.answers.all().order_by('-is_accepted', 'order', '-upvotes'))
    accepted_answer = next((a for a in answers if a.is_accepted), None)
    other_answers   = [a for a in answers if not a.is_accepted]

    return render(request, 'community/question.html', {
        'category': category,
        'question': question,
        'answers': answers,
        'accepted_answer': accepted_answer,
        'other_answers': other_answers,
        'related_questions': (
            CommunityQuestion.objects.filter(category=category, is_published=True)
            .exclude(pk=question.pk).order_by('-created_at')[:5]
        ),
        'all_categories': CommunityCategory.objects.filter(is_active=True).order_by('order'),
    })
```

