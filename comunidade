## 1. Models (`apps/community/models.py`)

```python
from django.db import models
from django.utils.text import slugify


class CommunityConfig(models.Model):
    """Singleton de configuração da comunidade."""
    openai_api_key      = models.CharField('OpenAI API Key', max_length=255, blank=True)
    openai_model        = models.CharField('Modelo', max_length=50, default='gpt-4o-mini',
                            choices=[('gpt-4o-mini','GPT-4o Mini (Padrão — Barato)'),('gpt-4o','GPT-4o (Premium)')])
    questions_per_day   = models.IntegerField('Perguntas por dia', default=20)
    answers_min         = models.IntegerField('Mín. respostas', default=6)
    answers_max         = models.IntegerField('Máx. respostas', default=12)
    generation_enabled  = models.BooleanField('Geração ativa', default=True)
    generation_hour     = models.IntegerField('Hora UTC do cron', default=8)
    last_generated_at   = models.DateTimeField(null=True, blank=True)
    created_at          = models.DateTimeField(auto_now_add=True)
    updated_at          = models.DateTimeField(auto_now=True)

    class Meta:
        verbose_name = 'Configuração da Comunidade'

    def __str__(self):
        return 'Configurações da Comunidade'

    @classmethod
    def get_solo(cls):
        obj, _ = cls.objects.get_or_create(pk=1)
        return obj


class CommunityCategory(models.Model):
    """Categorias temáticas da comunidade."""
    name            = models.CharField('Nome', max_length=100)
    slug            = models.SlugField(unique=True)
    description     = models.TextField('Descrição', blank=True)
    icon            = models.CharField('Ícone Lucide', max_length=50, default='message-circle')
    color           = models.CharField('Cor hex', max_length=7, default='#6366f1')
    seo_title       = models.CharField(max_length=60, blank=True)
    seo_description = models.CharField(max_length=160, blank=True)
    order           = models.IntegerField(default=0)
    is_active       = models.BooleanField(default=True)
    created_at      = models.DateTimeField(auto_now_add=True)

    class Meta:
        ordering = ['order', 'name']

    def __str__(self):
        return self.name

    # IMPORTANTE: não criar @property question_count aqui pois conflita com ORM annotation


class CommunityQuestion(models.Model):
    """Pergunta gerada por IA."""
    category        = models.ForeignKey(CommunityCategory, on_delete=models.CASCADE,
                        related_name='questions')
    title           = models.CharField(max_length=300)
    slug            = models.SlugField(max_length=320, unique=True)
    body            = models.TextField('Corpo')
    author_name     = models.CharField(max_length=100)   # nome humano gerado pela IA
    author_avatar   = models.CharField(max_length=80, blank=True)  # seed DiceBear
    seo_title       = models.CharField(max_length=80, blank=True)
    seo_description = models.CharField(max_length=200, blank=True)
    views           = models.IntegerField(default=0)
    answer_count    = models.IntegerField(default=0)     # cache
    is_published    = models.BooleanField(default=True)
    created_at      = models.DateTimeField(auto_now_add=True)
    updated_at      = models.DateTimeField(auto_now=True)

    class Meta:
        ordering = ['-created_at']
        indexes = [
            models.Index(fields=['category', 'is_published']),
            models.Index(fields=['slug']),
        ]

    def __str__(self):
        return self.title

    def save(self, *args, **kwargs):
        if not self.slug:
            base = slugify(self.title)[:300]
            slug, n = base, 1
            while CommunityQuestion.objects.filter(slug=slug).exclude(pk=self.pk).exists():
                slug = f'{base}-{n}'; n += 1
            self.slug = slug
        super().save(*args, **kwargs)


class CommunityAnswer(models.Model):
    """Resposta gerada por IA com persona humana."""
    question        = models.ForeignKey(CommunityQuestion, on_delete=models.CASCADE,
                        related_name='answers')
    body            = models.TextField()
    author_name     = models.CharField(max_length=100)
    author_avatar   = models.CharField(max_length=80, blank=True)  # seed DiceBear
    upvotes         = models.IntegerField(default=0)
    is_accepted     = models.BooleanField(default=False)
    order           = models.IntegerField(default=0)
    created_at      = models.DateTimeField(auto_now_add=True)

    class Meta:
        ordering = ['-is_accepted', 'order', '-upvotes']

    def __str__(self):
        return f'{self.author_name} → {self.question.title[:50]}'
