        "text": "{{ ans.body|escapejs }}",
        "dateCreated": "{{ ans.created_at|date:'Y-m-d' }}",
        "upvoteCount": {{ ans.upvotes }},
        "author": {"@type": "Person", "name": "{{ ans.author_name|escapejs }}"}
