## 4. Sitemap (`apps/community/sitemaps.py`)

```python
from django.contrib.sitemaps import Sitemap
from .models import CommunityCategory, CommunityQuestion


class CommunityCategorySitemap(Sitemap):
    changefreq = 'daily'
    priority = 0.7

    def items(self):
        return CommunityCategory.objects.filter(is_active=True).order_by('order')

    def location(self, obj):
        return f'/comunidade/{obj.slug}/'

    def lastmod(self, obj):
        latest = (
            CommunityQuestion.objects.filter(category=obj, is_published=True)
            .order_by('-created_at').values_list('created_at', flat=True).first()
        )
        return latest or obj.created_at


class CommunityQuestionSitemap(Sitemap):
    changefreq = 'weekly'
    priority = 0.8

    def items(self):
        return CommunityQuestion.objects.filter(is_published=True).select_related('category').order_by('-created_at')

    def location(self, obj):
        return f'/comunidade/{obj.category.slug}/{obj.slug}/'

    def lastmod(self, obj):
        return obj.updated_at
```

