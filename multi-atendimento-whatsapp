```python
import json, asyncio
from django.contrib.auth.decorators import login_required
from django.views.decorators.http import require_POST
from django.http import JsonResponse
from django.shortcuts import render, get_object_or_404
from django.views.decorators.csrf import csrf_exempt

from .models import WhatsAppInstance, Conversation, Message
from .whatsapp_manager import whatsapp_manager
from .services.message_handler import MessageHandler


# ── QR Code / Conexão ────────────────────────────────────────────────────────

@login_required
def instance_list(request):
    instances = WhatsAppInstance.objects.filter(tenant=request.tenant).order_by('name')
    return render(request, 'whatsapp/instance_list.html', {'instances': instances})


@login_required
@require_POST
def instance_create(request):
    data = json.loads(request.body)
    inst = WhatsAppInstance.objects.create(
        tenant=request.tenant,
        name=data.get('name', 'Nova Instância'),
        api_type=data.get('api_type', 'internal'),
    )
    return JsonResponse({'success': True, 'id': str(inst.id)})


@login_required
@require_POST
def instance_connect(request, pk):
    """
    BLOQUEANTE: aguarda QR code (até 25s).
    Frontend recebe QR direto na resposta HTTP.
    """
    inst = get_object_or_404(WhatsAppInstance, pk=pk, tenant=request.tenant)

    # Se já conectado
    if inst.status == 'connected':
        return JsonResponse({'success': True, 'status': 'connected'})

    inst.update_status('connecting', 'Iniciando conexão...')

    def on_qr(qr_b64):
        inst.set_qr_code(qr_b64)

    def on_connected():
        inst.update_status('connected', 'Conectado')

    def on_disconnected(reason):
        inst.update_status('disconnected', reason)

    def on_message(data):
        inst.refresh_from_db()
        handler = MessageHandler(inst.tenant, inst)
        handler.handle_incoming_message(data)
        inst.increment_messages(received=1)

    event = whatsapp_manager.connect_instance(
        str(inst.id), inst.get_session_path(),
        on_qr=on_qr,
        on_connected=on_connected,
        on_message=on_message,
        on_disconnected=on_disconnected,
    )

    # Aguarda QR ou conexão (máx 25s)
    qr = whatsapp_manager.wait_for_qr(str(inst.id), timeout=25)

    if qr:
        return JsonResponse({'success': True, 'status': 'qr_code', 'qr_code': qr})

    inst.refresh_from_db()
    if inst.status == 'connected':
        return JsonResponse({'success': True, 'status': 'connected'})

    return JsonResponse({'success': False, 'error': 'timeout generating QR'}, status=408)


@login_required
@require_POST
def instance_disconnect(request, pk):
    inst = get_object_or_404(WhatsAppInstance, pk=pk, tenant=request.tenant)
    whatsapp_manager.disconnect_instance(str(inst.id))
    inst.update_status('disconnected', 'Desconectado manualmente')
    return JsonResponse({'success': True})


@login_required
def instance_status(request, pk):
    inst = get_object_or_404(WhatsAppInstance, pk=pk, tenant=request.tenant)
    return JsonResponse({
        'status': inst.status,
        'phone_number': inst.phone_number,
        'messages_sent': inst.messages_sent,
        'messages_received': inst.messages_received,
    })


# ── Envio de mensagens ───────────────────────────────────────────────────────

@login_required
@require_POST
def send_message(request, pk):
    """Envia texto ou mídia por uma conversa."""
    conv = get_object_or_404(Conversation, pk=pk, tenant=request.tenant)
    data = json.loads(request.body)

    content   = data.get('content', '').strip()
    msg_type  = data.get('type', 'text')

    if not content:
        return JsonResponse({'error': 'empty message'}, status=400)

    handler = MessageHandler(request.tenant)
    msg = handler.create_outgoing_message(
        conversation=conv,
        content=content,
        message_type=msg_type,
        sender_type='user',
        sender_user=request.user,
    )

    # Envio real via Neonize
    inst = conv.instance
    if inst and inst.status == 'connected':
        client = whatsapp_manager.get_client(str(inst.id))
        if client and client.is_connected:
            jid = conv.contact.jid
            try:
                wa_id = asyncio.run(client.send_text(jid, content))
                msg.message_id = wa_id
                msg.status     = 'sent'
                msg.save(update_fields=['message_id', 'status'])
                inst.increment_messages(sent=1)
            except Exception as e:
                msg.status = 'failed'
                msg.save(update_fields=['status'])

    return JsonResponse({
        'success': True,
        'message_id': msg.id,
        'status': msg.status,
    })


# ── API de polling ────────────────────────────────────────────────────────────

@login_required
def api_conversations_list(request):
    """Lista conversas com status calculado — usado pelo frontend Alpine.js."""
    convs = (
        Conversation.objects
        .filter(tenant=request.tenant, is_archived=False)
        .select_related('contact', 'assigned_to', 'department')
        .order_by('-last_message_at')[:200]
    )
    data = []
    for c in convs:
        data.append({
            'id':                    c.id,
            'contact_name':          c.contact.display_name,
            'contact_phone':         c.contact.phone,
            'last_message_text':     c.last_message_text,
            'last_message_at':       c.last_message_at.isoformat() if c.last_message_at else '',
            'status':                c.status,
            'effective_status':      c.effective_status,
            'unread_count':          c.unread_count,
            'ai_enabled':            c.ai_enabled,
            'assigned_to_id':        c.assigned_to_id,
            'department_id':         c.department_id,
            'last_message_sentiment': c.last_message_sentiment,
            'is_mine':               c.assigned_to_id == request.user.id,
        })
    return JsonResponse({'conversations': data})
