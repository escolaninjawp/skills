                Expira em <span id="countdown">20</span>s
            </p>
            <p class="text-xs text-gray-400 mt-1">Abra o WhatsApp → Dispositivos Conectados → Conectar</p>
        </div>

        <!-- Conectado -->
        <div id="qr-connected" class="hidden py-8">
            <div class="text-green-500 text-5xl mb-2">✓</div>
            <p class="font-bold text-green-600">Conectado!</p>
        </div>

        <button onclick="closeQRModal()" class="mt-4 text-sm text-gray-400 hover:text-gray-600">Fechar</button>
    </div>
</div>

<script>
let currentInstanceId = null;
let pollTimer = null;
let countdownTimer = null;

async function connectInstance(instanceId) {
    currentInstanceId = instanceId;
    document.getElementById('qr-modal').classList.remove('hidden');
    document.getElementById('qr-spinner').classList.remove('hidden');
    document.getElementById('qr-image').classList.add('hidden');
    document.getElementById('qr-connected').classList.add('hidden');

    try {
        // Chamada BLOQUEANTE — servidor aguarda QR (até 25s)
        const r = await fetch(`/whatsapp/api/instancia/${instanceId}/connect/`, {method: 'POST'});
        const data = await r.json();

        document.getElementById('qr-spinner').classList.add('hidden');

        if (data.status === 'connected') {
            showConnected();
        } else if (data.qr_code) {
            showQR(data.qr_code);
            startPoll();
        } else {
            alert('Erro ao gerar QR: ' + (data.error || 'unknown'));
        }
    } catch(e) {
        alert('Erro de conexão: ' + e);
    }
}

function showQR(qrBase64) {
    document.getElementById('qr-image').classList.remove('hidden');
    document.getElementById('qr-img').src = 'data:image/png;base64,' + qrBase64;
    startCountdown(20, () => connectInstance(currentInstanceId));  // Auto-refresh
}

function startCountdown(seconds, onExpire) {
    clearInterval(countdownTimer);
    let s = seconds;
    document.getElementById('countdown').textContent = s;
    countdownTimer = setInterval(() => {
        s--;
        document.getElementById('countdown').textContent = s;
        if (s <= 0) { clearInterval(countdownTimer); onExpire(); }
    }, 1000);
}

function startPoll() {
    clearInterval(pollTimer);
    pollTimer = setInterval(async () => {
        const r = await fetch(`/whatsapp/api/instancia/${currentInstanceId}/status/`);
        const data = await r.json();
        if (data.status === 'connected') {
            clearInterval(pollTimer);
            clearInterval(countdownTimer);
            showConnected();
        }
    }, 2000);
}

function showConnected() {
    document.getElementById('qr-image').classList.add('hidden');
    document.getElementById('qr-connected').classList.remove('hidden');
    setTimeout(() => { window.location.reload(); }, 1500);
}

function closeQRModal() {
    clearInterval(pollTimer);
    clearInterval(countdownTimer);
    document.getElementById('qr-modal').classList.add('hidden');
}
</script>
