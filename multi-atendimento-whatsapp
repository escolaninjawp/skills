class Conversation(models.Model):
    STATUS_CHOICES = [
        ('open',        'Aberta'),
        ('pending',     'Pendente'),
        ('in_progress', 'Em Atendimento'),
        ('resolved',    'Resolvida'),
        ('closed',      'Fechada'),
    ]
    CHANNEL_CHOICES = [
        ('whatsapp',  'WhatsApp'),
        ('telegram',  'Telegram'),
        ('instagram', 'Instagram'),
        ('webchat',   'Chat do Site'),
    ]
    SENTIMENT_CHOICES = [
        ('positive', 'Positivo'),
        ('negative', 'Negativo'),
        ('neutral',  'Neutro'),
    ]

    tenant      = models.ForeignKey(Tenant, on_delete=models.CASCADE)
    instance    = models.ForeignKey(WhatsAppInstance, null=True, blank=True, on_delete=models.SET_NULL)
    contact     = models.ForeignKey(WhatsAppContact, on_delete=models.CASCADE)
    lead        = models.ForeignKey('crm.Lead', null=True, blank=True, on_delete=models.SET_NULL)
    channel     = models.CharField(max_length=20, choices=CHANNEL_CHOICES, default='whatsapp')
    department  = models.ForeignKey(Department, null=True, blank=True, on_delete=models.SET_NULL)
    assigned_to = models.ForeignKey(User, null=True, blank=True, on_delete=models.SET_NULL)

    status = models.CharField(max_length=20, choices=STATUS_CHOICES, default='open')

    # Cache da última mensagem
    last_message_text           = models.TextField(blank=True)
    last_message_at             = models.DateTimeField(null=True, blank=True)
    last_message_from_contact   = models.BooleanField(default=True)
    last_message_sentiment      = models.CharField(max_length=10, choices=SENTIMENT_CHOICES, blank=True)
    last_message_sentiment_reason = models.CharField(max_length=200, blank=True)

    unread_count  = models.PositiveIntegerField(default=0)
    message_count = models.PositiveIntegerField(default=0)

    ai_enabled    = models.BooleanField(default=True)
    ai_paused_until = models.DateTimeField(null=True, blank=True)

    is_group    = models.BooleanField(default=False)
    is_archived = models.BooleanField(default=False)

    tags = models.JSONField(default=list)
    conversation_tags = models.ManyToManyField(ConversationTag, blank=True)
    metadata = models.JSONField(default=dict)

    started_at         = models.DateTimeField(auto_now_add=True)
    first_response_at  = models.DateTimeField(null=True, blank=True)
    resolved_at        = models.DateTimeField(null=True, blank=True)
    closed_at          = models.DateTimeField(null=True, blank=True)
    updated_at         = models.DateTimeField(auto_now=True)

    class Meta:
        ordering = ['-last_message_at']
        indexes  = [
            models.Index(fields=['tenant', 'status']),
            models.Index(fields=['tenant', 'last_message_at']),
        ]

    @property
    def is_waiting_first_response(self):
        return self.first_response_at is None

    @property
    def is_waiting_interaction(self):
        return (
            self.first_response_at is not None
            and self.last_message_from_contact
            and self.status not in ('resolved', 'closed')
        )

    @property
    def effective_status(self):
        if self.status in ('resolved', 'closed'):
            return self.status
        if self.is_waiting_first_response:
            return 'waiting_service'
        if self.is_waiting_interaction:
            return 'waiting_response'
        return self.status

    def mark_as_read(self):
        self.unread_count = 0
        self.save(update_fields=['unread_count'])

    def pause_ai(self, hours=24):
        self.ai_paused_until = timezone.now() + timezone.timedelta(hours=hours)
        self.save(update_fields=['ai_paused_until'])

    def resume_ai(self):
        self.ai_paused_until = None
        self.save(update_fields=['ai_paused_until'])

    def close(self):
        self.status = 'closed'
        self.closed_at = timezone.now()
        self.save(update_fields=['status', 'closed_at'])


