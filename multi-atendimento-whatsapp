```python
import asyncio, secrets, threading, time, logging
from typing import Dict, Optional, Callable

logger = logging.getLogger(__name__)


class WhatsAppManager:
    """
    Singleton que gerencia TODAS as instâncias ativas.
    Thread-safe. Uma thread por instância.
    """

    _instance = None
    _lock     = threading.Lock()

    def __new__(cls):
        if cls._instance is None:
            with cls._lock:
                if cls._instance is None:
                    cls._instance = super().__new__(cls)
                    cls._instance._init()
        return cls._instance

    def _init(self):
        from .services.neonize_client import NeonizeClient
        self._NeonizeClient = NeonizeClient

        self.clients:    Dict[str, 'NeonizeClient'] = {}
        self.threads:    Dict[str, threading.Thread] = {}
        self._tokens:    Dict[str, str] = {}         # instance_id → token
        self._last_connect: Dict[str, float] = {}
        self._msg_ids:   Dict[str, float] = {}       # dedup
        self._msg_lock   = threading.Lock()
        self._qr_events: Dict[str, threading.Event] = {}
        self._qr_codes:  Dict[str, str] = {}

    # ── Conexão ──────────────────────────────────────────────────────────────

    def connect_instance(self, instance_id: str, session_path: str,
                         on_qr=None, on_connected=None,
                         on_message=None, on_disconnected=None):
        """
        Conecta uma instância em background thread.
        Rate limit: máx 1 tentativa a cada 30s por instância.
        """
        iid = str(instance_id)

        # Rate limit
        if time.time() - self._last_connect.get(iid, 0) < 30:
            logger.warning(f"Rate limit atingido: {iid}")
            return
        self._last_connect[iid] = time.time()

        # Token garante que callbacks stale sejam ignorados
        token = secrets.token_hex(16)
        self._tokens[iid] = token
        event = threading.Event()
        self._qr_events[iid] = event

        client = self._NeonizeClient(session_path)

        def _on_qr(qr_b64):
            if self._tokens.get(iid) != token:
                return
            self._qr_codes[iid] = qr_b64
            event.set()
            if on_qr:
                on_qr(qr_b64)

        def _on_connected():
            if self._tokens.get(iid) != token:
                return
            self._qr_codes.pop(iid, None)
            event.set()
            if on_connected:
                on_connected()

        def _on_message(data):
            if self._tokens.get(iid) != token:
                return
            mid = data.message_id
            now = time.time()
            with self._msg_lock:
                if mid and mid in self._msg_ids and now - self._msg_ids[mid] < 5:
                    logger.debug(f"Msg duplicada ignorada: {mid}")
                    return
                if mid:
                    self._msg_ids[mid] = now
            if on_message:
                on_message(data)

        def _on_disconnected(reason):
            if self._tokens.get(iid) != token:
                return
            if on_disconnected:
                on_disconnected(reason)

        client.on_qr           = _on_qr
        client.on_connected    = _on_connected
        client.on_message      = _on_message
        client.on_disconnected = _on_disconnected

        self.clients[iid] = client

        def _run():
            try:
                asyncio.run(client.connect())
            except Exception as e:
                logger.exception(f"Erro na thread de {iid}: {e}")

        t = threading.Thread(target=_run, name=f'WA-{iid[:8]}', daemon=False)
        self.threads[iid] = t
        t.start()

        return event   # Caller pode esperar pelo QR

    def disconnect_instance(self, instance_id: str):
        iid = str(instance_id)
        client = self.clients.pop(iid, None)
        if client and client.is_connected:
            try:
                asyncio.run(client.disconnect())
            except Exception:
                pass
        self._tokens.pop(iid, None)
        self._qr_codes.pop(iid, None)

    def get_client(self, instance_id: str):
        return self.clients.get(str(instance_id))

    def get_qr_code(self, instance_id: str) -> Optional[str]:
        return self._qr_codes.get(str(instance_id))

    def wait_for_qr(self, instance_id: str, timeout=25) -> Optional[str]:
        """Aguarda QR code ficar disponível (máx timeout segundos)."""
        event = self._qr_events.get(str(instance_id))
        if event:
            event.wait(timeout=timeout)
            event.clear()
        return self.get_qr_code(instance_id)

    def startup_reconnect(self):
        """Chamado no startup do Django. Reconecta instâncias que estavam ativas."""
        try:
            from .models import WhatsAppInstance
            from .services.message_handler import MessageHandler
            from apps.tenants.models import Tenant

            for inst in WhatsAppInstance.objects.filter(
                api_type='internal',
                status__in=['connected', 'connecting'],
            ).select_related('tenant'):

                def make_callbacks(i):
                    def on_msg(data):
                        handler = MessageHandler(i.tenant, i)
                        handler.handle_incoming_message(data)
                    def on_conn():
                        i.update_status('connected', 'Reconectado')
                    def on_disc(reason):
                        i.update_status('disconnected', reason)
                    return on_msg, on_conn, on_disc

                on_msg, on_conn, on_disc = make_callbacks(inst)
                self.connect_instance(
                    str(inst.id), inst.get_session_path(),
                    on_message=on_msg, on_connected=on_conn, on_disconnected=on_disc
                )
                logger.info(f"Reconectando: {inst.name}")
        except Exception as e:
            logger.exception(f"Erro no startup_reconnect: {e}")


# Singleton global
whatsapp_manager = WhatsAppManager()
