## 2. Neonize Client (services/neonize_client.py)

```python
import asyncio, logging
from dataclasses import dataclass, field
from typing import Optional, Callable

logger = logging.getLogger(__name__)


@dataclass
class MessageData:
    """Estrutura de mensagem recebida pelo Neonize."""
    message_id:      str
    jid:             str         # "5511...@s.whatsapp.net"
    phone:           str
    push_name:       str
    message_type:    str         # "text", "image", "audio", etc.
    content:         str
    timestamp:       float       # Unix timestamp
    is_group:        bool = False
    group_jid:       str  = ''
    media_url:       str  = ''
    media_mime_type: str  = ''
    media_filename:  str  = ''
    quoted_message_id: str = ''
    latitude:        Optional[float] = None
    longitude:       Optional[float] = None


class NeonizeClient:
    """
    Wrapper assíncrono em torno da biblioteca Neonize.
    Uso:
        client = NeonizeClient(session_path='/path/to/session.db')
        client.on_qr      = lambda qr: ...        # qr = base64 PNG
        client.on_connected  = lambda: ...
        client.on_message = lambda data: ...       # data = MessageData
        asyncio.run(client.connect())
    """

    def __init__(self, session_path: str, tenant_id=None):
        self.session_path = session_path
        self.tenant_id    = tenant_id
        self.client       = None
        self._connected   = False

        # Callbacks
        self.on_qr:              Optional[Callable] = None
        self.on_connected:       Optional[Callable] = None
        self.on_disconnected:    Optional[Callable] = None
        self.on_message:         Optional[Callable] = None
        self.on_message_status:  Optional[Callable] = None

    @property
    def is_connected(self):
        return self._connected

    async def connect(self):
        from neonize.client import NewClient
        from neonize.events import (
            ConnectedEv, DisconnectedEv, QREv, MessageEv, ReceiptEv,
        )

        self.client = NewClient(self.session_path)

        @self.client.event(QREv)
        async def _on_qr(client, event):
            qr_b64 = event.qr
            logger.info("QR gerado")
            if self.on_qr:
                self.on_qr(qr_b64)

        @self.client.event(ConnectedEv)
        async def _on_connected(client, event):
            self._connected = True
            logger.info("Conectado ao WhatsApp")
            if self.on_connected:
                self.on_connected()

        @self.client.event(DisconnectedEv)
        async def _on_disconnected(client, event):
            self._connected = False
            reason = getattr(event, 'Reason', 'unknown')
            logger.warning(f"Desconectado: {reason}")
            if self.on_disconnected:
                self.on_disconnected(str(reason))

        @self.client.event(MessageEv)
        async def _on_message(client, event):
            try:
                info = event.Info
                msg_type = str(event.Type or 'text').lower()

                content = ''
                media_url = media_mime = media_filename = ''

                if hasattr(event.Message, 'Conversation'):
                    content = event.Message.Conversation or ''
                elif hasattr(event.Message, 'ExtendedTextMessage'):
                    content = (event.Message.ExtendedTextMessage.Text or '')

                # Mídia
                if msg_type in ('image', 'video', 'audio', 'document', 'sticker'):
                    try:
                        media_data = await client.Download(event.Message)
                        # Salve media_data em storage e gere URL
                        # media_url = save_media(media_data, msg_type)
                    except Exception as e:
                        logger.warning(f"Erro ao baixar mídia: {e}")

                data = MessageData(
                    message_id=info.ID or '',
                    jid=str(info.Sender or info.Chat or ''),
                    phone=str(info.Sender or '').split('@')[0],
                    push_name=str(event.PushName or ''),
                    message_type=msg_type,
                    content=content.strip(),
                    timestamp=float(info.Timestamp or 0),
                    is_group=bool(info.IsGroup),
                    group_jid=str(info.Chat) if info.IsGroup else '',
                    media_url=media_url,
                    media_mime_type=media_mime,
                    media_filename=media_filename,
                )

                if self.on_message:
                    self.on_message(data)

            except Exception as e:
                logger.exception(f"Erro ao processar mensagem: {e}")

        @self.client.event(ReceiptEv)
        async def _on_receipt(client, event):
            if self.on_message_status:
                self.on_message_status(str(event.MessageID), str(event.Type))

        await self.client.connect()

    async def send_text(self, jid: str, text: str) -> str:
        """Envia texto. Retorna message_id."""
        result = await self.client.SendMessage(jid, text)
        return str(result.ID) if result else ''

    async def send_image(self, jid: str, image_bytes: bytes, caption='') -> str:
        from neonize.proto.waE2E.WAWebProtobufsE2E_pb2 import ImageMessage
        msg = ImageMessage(Caption=caption)
        result = await self.client.SendImage(jid, image_bytes, msg)
        return str(result.ID) if result else ''

    async def send_audio(self, jid: str, audio_bytes: bytes, ptt=False) -> str:
        from neonize.proto.waE2E.WAWebProtobufsE2E_pb2 import AudioMessage
        msg = AudioMessage(PTT=ptt)
        result = await self.client.SendAudio(jid, audio_bytes, msg)
        return str(result.ID) if result else ''

    async def send_document(self, jid: str, doc_bytes: bytes, filename='document') -> str:
        from neonize.proto.waE2E.WAWebProtobufsE2E_pb2 import DocumentMessage
        msg = DocumentMessage(FileName=filename)
        result = await self.client.SendDocument(jid, doc_bytes, msg)
        return str(result.ID) if result else ''

    async def disconnect(self):
        if self.client:
            try:
                await self.client.Disconnect()
            except Exception:
                pass
        self._connected = False
