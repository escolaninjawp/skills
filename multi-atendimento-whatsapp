```python
import logging
from datetime import datetime
from django.db import transaction
from django.utils import timezone

from ..models import WhatsAppContact, Conversation, Message, WhatsAppInstance
from .neonize_client import MessageData
from .sentiment import analyze_sentiment

logger = logging.getLogger(__name__)


class MessageHandler:

    def __init__(self, tenant, instance: WhatsAppInstance = None):
        self.tenant   = tenant
        self.instance = instance

    @transaction.atomic
    def handle_incoming_message(self, data: MessageData) -> Message | None:
        """
        Fluxo completo de mensagem recebida:
        1. Ignora grupos
        2. Cria/atualiza contato
        3. Cria/recupera conversa
        4. Cria Message no banco
        5. Atualiza cache da conversa
        6. Analisa sentimento (inline, sem Celery)
        7. Gera resposta de IA (se habilitado)
        """

        # 1. Ignora grupos
        if data.is_group:
            return None

        # 2. Contato
        contact = self._get_or_create_contact(data)

        # 3. Conversa
        conversation = self._get_or_create_conversation(contact)

        # Evita mensagem duplicada pelo message_id
        if data.message_id and Message.objects.filter(
            conversation=conversation, message_id=data.message_id
        ).exists():
            return None

        # 4. Cria mensagem
        ts = datetime.fromtimestamp(data.timestamp, tz=timezone.utc) if data.timestamp else timezone.now()
        message = Message.objects.create(
            conversation=conversation,
            message_id=data.message_id or '',
            message_type=data.message_type or 'text',
            content=data.content,
            sender_type='contact',
            status='delivered',
            timestamp=ts,
            media_url=data.media_url or '',
            media_mime_type=data.media_mime_type or '',
            media_filename=data.media_filename or '',
            latitude=data.latitude,
            longitude=data.longitude,
        )

        # 5. Atualiza cache da conversa
        conversation.last_message_text         = data.content[:500]
        conversation.last_message_at           = ts
        conversation.last_message_from_contact = True
        conversation.unread_count              = conversation.unread_count + 1
        conversation.message_count             = conversation.message_count + 1
        update_fields = [
            'last_message_text', 'last_message_at', 'last_message_from_contact',
            'unread_count', 'message_count',
        ]

        # 6. Sentimento
        if data.content:
            try:
                from apps.core.models import SystemSettings
                gemini_key = SystemSettings.get_settings().gemini_api_key
            except Exception:
                gemini_key = ''

            if not gemini_key and self.instance:
                gemini_key = self.instance.gemini_api_key

            if gemini_key:
                result = analyze_sentiment(data.content, gemini_key)
                if result:
                    message.sentiment = result['sentiment']
                    message.save(update_fields=['sentiment'])
                    conversation.last_message_sentiment        = result['sentiment']
                    conversation.last_message_sentiment_reason = result.get('reason', '')[:200]
                    update_fields += ['last_message_sentiment', 'last_message_sentiment_reason']

        conversation.save(update_fields=update_fields)

        # 7. IA (implemente conforme seu AI agent)
        # self._generate_ai_response(message, conversation)

        return message

    def _get_or_create_contact(self, data: MessageData) -> WhatsAppContact:
        phone_norm = self._normalize_phone(data.phone)
        contact, created = WhatsAppContact.objects.update_or_create(
            tenant=self.tenant,
            jid=data.jid,
            defaults={
                'phone': data.phone,
                'phone_normalized': phone_norm,
                'push_name': data.push_name or '',
            },
        )
        if created:
            self._link_to_lead(contact, phone_norm)
        return contact

    def _get_or_create_conversation(self, contact: WhatsAppContact) -> Conversation:
        conv = Conversation.objects.filter(
            tenant=self.tenant,
            contact=contact,
            status__in=['open', 'pending', 'in_progress'],
        ).first()

        if not conv:
            conv = Conversation.objects.create(
                tenant=self.tenant,
                instance=self.instance,
                contact=contact,
                lead=contact.lead,
                channel='whatsapp',
                status='open',
            )

        return conv

    def _link_to_lead(self, contact: WhatsAppContact, phone_norm: str):
        """Vincula contato ao Lead do CRM pelo telefone."""
        try:
            from apps.crm.models import Lead
            lead = Lead.objects.filter(
                tenant=self.tenant,
                phone_normalized=phone_norm,
                is_active=True,
            ).first()
            if lead:
                contact.lead = lead
                contact.save(update_fields=['lead'])
        except Exception as e:
            logger.warning(f"Erro ao vincular lead: {e}")

    @staticmethod
    def _normalize_phone(phone: str) -> str:
        import re
        return re.sub(r'\D', '', phone or '')

    def create_outgoing_message(self, conversation: Conversation,
                                content: str, message_type='text',
                                sender_type='user', sender_user=None,
                                ai_generated=False, ai_model='', ai_tokens=0,
                                media_url='', media_mime_type='',
                                media_filename='') -> Message:
        message = Message.objects.create(
            conversation=conversation,
            message_type=message_type,
            content=content,
            sender_type=sender_type,
            sender_user=sender_user,
            status='pending',
            ai_generated=ai_generated,
            ai_model=ai_model,
            ai_tokens_used=ai_tokens,
            media_url=media_url,
            media_mime_type=media_mime_type,
            media_filename=media_filename,
        )

        ts = timezone.now()
        conversation.last_message_text         = content[:500]
        conversation.last_message_at           = ts
        conversation.last_message_from_contact = False
        conversation.message_count             = conversation.message_count + 1
        if conversation.first_response_at is None:
            conversation.first_response_at = ts
            conversation.save(update_fields=[
                'last_message_text', 'last_message_at', 'last_message_from_contact',
                'message_count', 'first_response_at',
            ])
        else:
            conversation.save(update_fields=[
                'last_message_text', 'last_message_at', 'last_message_from_contact',
                'message_count',
            ])

        return message
