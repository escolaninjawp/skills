import uuid, secrets
from django.db import models
from django.utils import timezone
from apps.tenants.models import Tenant
from apps.core.models import User


# ─── WhatsAppInstance ────────────────────────────────────────────────────────

class WhatsAppInstance(models.Model):
    """Uma linha WhatsApp (número) por instância. Tenant pode ter várias."""

    API_TYPE_CHOICES = [
        ('internal', 'API Vitória CRM (QR Code)'),
        ('official', 'WhatsApp Business API (Meta)'),
        ('chatpro',  'ChatPRO'),
    ]
    STATUS_CHOICES = [
        ('disconnected', 'Desconectado'),
        ('connecting',   'Conectando'),
        ('qr_code',      'Aguardando QR'),
        ('connected',    'Conectado'),
        ('error',        'Erro'),
    ]

    id             = models.UUIDField(primary_key=True, default=uuid.uuid4, editable=False)
    tenant         = models.ForeignKey(Tenant, on_delete=models.CASCADE, related_name='whatsapp_instances')
    api_type       = models.CharField(max_length=20, choices=API_TYPE_CHOICES, default='internal')
    name           = models.CharField('Nome', max_length=100)

    # Autenticação
    api_key        = models.CharField(max_length=64, blank=True, unique=True)
    webhook_url    = models.URLField(blank=True)
    chatpro_webhook_token = models.CharField(max_length=64, blank=True, null=True, unique=True)

    # Status
    status         = models.CharField(max_length=20, choices=STATUS_CHOICES, default='disconnected')
    status_message = models.TextField(blank=True)

    # Sessão
    phone_number   = models.CharField(max_length=20, blank=True)
    device_name    = models.CharField(max_length=100, blank=True)
    session_path   = models.CharField(max_length=500, blank=True)

    # QR Code
    qr_code             = models.TextField(blank=True)   # base64 PNG
    qr_code_updated_at  = models.DateTimeField(null=True, blank=True)

    # Estatísticas
    messages_sent     = models.PositiveIntegerField(default=0)
    messages_received = models.PositiveIntegerField(default=0)
    last_activity     = models.DateTimeField(null=True, blank=True)

    # Configurações
    auto_reply_enabled   = models.BooleanField(default=True)
    ai_enabled           = models.BooleanField(default=True)
    business_hours_only  = models.BooleanField(default=False)
    sentiment_enabled    = models.BooleanField(default=True)
    gemini_api_key       = models.CharField(max_length=200, blank=True)

    connected_at    = models.DateTimeField(null=True, blank=True)
    disconnected_at = models.DateTimeField(null=True, blank=True)
    created_at      = models.DateTimeField(auto_now_add=True)
    updated_at      = models.DateTimeField(auto_now=True)

    class Meta:
        verbose_name = 'Instância WhatsApp'

    def __str__(self):
        return f'{self.tenant} – {self.name}'

    def save(self, *args, **kwargs):
        if not self.api_key:
            self.api_key = 'wapi_' + secrets.token_hex(28)
        super().save(*args, **kwargs)

    def get_session_path(self):
        from django.conf import settings
        import os
        base = getattr(settings, 'WHATSAPP_SESSION_PATH',
                       os.path.join(settings.BASE_DIR, 'whatsapp_sessions'))
        os.makedirs(base, exist_ok=True)
        return os.path.join(base, f'instance_{self.id}.db')

    def get_or_create_chatpro_token(self):
        if not self.chatpro_webhook_token:
            self.chatpro_webhook_token = secrets.token_hex(32)
            self.save(update_fields=['chatpro_webhook_token'])
        return self.chatpro_webhook_token

    def update_status(self, status, message=''):
        self.status = status
        self.status_message = message
        if status == 'connected':
            self.connected_at = timezone.now()
        elif status == 'disconnected':
            self.disconnected_at = timezone.now()
            self.qr_code = ''
        self.save(update_fields=['status', 'status_message',
                                  'connected_at', 'disconnected_at', 'qr_code'])

    def set_qr_code(self, qr_base64):
        self.qr_code = qr_base64
        self.qr_code_updated_at = timezone.now()
        self.status = 'qr_code'
        self.save(update_fields=['qr_code', 'qr_code_updated_at', 'status'])

    def increment_messages(self, sent=0, received=0):
        WhatsAppInstance.objects.filter(pk=self.pk).update(
            messages_sent=models.F('messages_sent') + sent,
            messages_received=models.F('messages_received') + received,
            last_activity=timezone.now(),
        )

    @property
    def is_connected(self):
        return self.status == 'connected'


