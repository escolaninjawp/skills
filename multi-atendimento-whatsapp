## 6. ChatPRO Webhook (chatpro_webhook.py)

```python
import re, json, logging
from django.views.decorators.csrf import csrf_exempt
from django.views.decorators.http import require_POST
from django.http import JsonResponse

logger = logging.getLogger(__name__)

# Eventos ignorados
IGNORED_EVENTS = {
    'sent_message', 'transfer_session', 'session_closed', 'session_paused',
}

# Tipos de mídia (sem texto)
MEDIA_TYPES = {
    'receveid_audio_message': '🎤 Áudio',
    'receveid_image_message': '📷 Imagem',
    'receveid_video_message': '📹 Vídeo',
    'receveid_document_message': '📄 Documento',
    'receveid_sticker_message': '🎭 Sticker',
}


@csrf_exempt
@require_POST
def chatpro_webhook(request, token: str):
    """
    Recebe mensagens do ChatPRO e salva no CRM.

    URL: /api/webhooks/chatpro/<token>/

    Payload esperado:
    {
        "event": "received_message",
        "message_data": {
            "id": "ABC123",
            "from_me": false,
            "number": "5521999999999@s.whatsapp.net",
            "message": "Olá",
            "type": "receveid_message",
            "push_name": "João"
        }
    }
    """
    from .models import WhatsAppInstance
    from apps.crm.models import (
        Lead, LeadSource, LeadActivity, LeadNote,
        LeadOpportunity, Pipeline,
    )

    # 1. Valida token
    try:
        instance = WhatsAppInstance.objects.select_related('tenant').get(
            chatpro_webhook_token=token,
            api_type='chatpro',
        )
    except WhatsAppInstance.DoesNotExist:
        return JsonResponse({'error': 'invalid token'}, status=401)

    tenant = instance.tenant

    # 2. Parse do payload
    try:
        data = json.loads(request.body)
    except (json.JSONDecodeError, Exception):
        return JsonResponse({'error': 'invalid json'}, status=400)

    event    = data.get('event', '')
    msg_data = data.get('message_data') or {}

    # 3. Ignora eventos desnecessários
    if event in IGNORED_EVENTS:
        return JsonResponse({'ok': True, 'skipped': True})

    # 4. Ignora mensagens do próprio número
    if msg_data.get('from_me') is True:
        return JsonResponse({'ok': True, 'skipped': True, 'reason': 'from_me'})

    # 5. Extrai dados
    number_raw    = msg_data.get('number') or msg_data.get('participant') or ''
    phone_norm    = re.sub(r'\D', '', number_raw)
    body          = str(msg_data.get('message') or '').strip()
    msg_type      = msg_data.get('type', '')
    msg_id        = msg_data.get('id', '')
    push_name     = msg_data.get('push_name') or ''

    # 6. Ignora se sem conteúdo nem mídia reconhecida
    is_media = not body and msg_type in MEDIA_TYPES
    if not body and not is_media:
        return JsonResponse({'ok': True, 'skipped': True})

    if not phone_norm:
        return JsonResponse({'error': 'missing number'}, status=400)

    try:
        # 7. Deduplicação por msg_id
        if msg_id and LeadActivity.objects.filter(
            metadata__chatpro_msg_id=msg_id
        ).exists():
            return JsonResponse({'ok': True, 'skipped': True, 'reason': 'duplicate'})

        # 8. Cria ou recupera Lead
        lead = Lead.objects.filter(
            tenant=tenant,
            phone_normalized=phone_norm,
            is_active=True,
        ).first()

        if not lead:
            pipeline = Pipeline.objects.filter(tenant=tenant).order_by('id').first()
            if not pipeline:
                return JsonResponse({'error': 'no pipeline'}, status=500)

            stage = pipeline.stages.order_by('order').first()
            if not stage:
                return JsonResponse({'error': 'no stage'}, status=500)

            source, _ = LeadSource.objects.get_or_create(
                tenant=tenant,
                slug='whatsapp',
                defaults={'name': 'WhatsApp'},
            )

            lead = Lead.objects.create(
                tenant=tenant,
                name=push_name or f'WhatsApp {phone_norm[-4:]}',
                phone=phone_norm,
                source=source,
                pipeline=pipeline,
                stage=stage,
                temperature='warm',
            )

            # Oportunidade para aparecer no Kanban
            LeadOpportunity.objects.create(
                lead=lead,
                stage=stage,
                notes=f'Origem: ChatPRO. "{body[:200]}"',
            )

            LeadActivity.objects.create(
                lead=lead,
                activity_type='created',
                description=f'Lead criado via ChatPRO webhook.',
            )

        # 9. Salva nota com a mensagem
        if body:
            LeadNote.objects.create(
                lead=lead,
                content=f'📱 WhatsApp (ChatPRO):\n{body}',
            )
            activity_desc = body[:500]
        else:
            activity_desc = MEDIA_TYPES.get(msg_type, f'Mídia ({msg_type})')

        # 10. Registra atividade (usado também para dedup por msg_id)
        LeadActivity.objects.create(
            lead=lead,
            activity_type='whatsapp_received',
            description=activity_desc,
            metadata={
                'chatpro_msg_id': msg_id,
                'number': number_raw,
                'event': event,
            },
        )

        return JsonResponse({'ok': True, 'lead_id': lead.id})

    except Exception as e:
        logger.exception(f'ChatPRO webhook error: {e}')
        return JsonResponse({'error': 'internal error'}, status=500)
