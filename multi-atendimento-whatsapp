## 4. Análise de Sentimento (services/sentiment.py)

```python
import re, json, logging, requests

logger = logging.getLogger(__name__)

GEMINI_URL = (
    "https://generativelanguage.googleapis.com/v1beta/models/"
    "gemini-2.5-flash:generateContent"
)

PROMPT = (
    "Analise o sentimento desta mensagem de cliente em português e responda SOMENTE com JSON: "
    '{"sentiment": "positive|negative|neutral", "reason": "motivo breve em até 80 chars"}'
    "\n\nMensagem: {text}"
)

POSITIVE_WORDS = [
    'obrigado','obrigada','ótimo','excelente','perfeito','adorei','amei',
    'maravilhoso','incrível','gostei','show','top','rápido','bom','boa',
    'muito bom','parabéns','satisfeito','satisfeita','recebi','chegou',
]
NEGATIVE_WORDS = [
    'ruim','péssimo','horrível','insatisfeito','reclamação','problema',
    'erro','falha','urgente','atrasado','atraso','não chegou','cancelar',
    'devolver','defeito','quebrou','não funciona','decepcionado','absurdo',
    'raiva','irritado','péssima','demora','demora','lento','lenta',
]


def analyze_sentiment(text: str, api_key: str) -> dict | None:
    """
    Retorna {'sentiment': 'positive'|'negative'|'neutral', 'reason': str}
    ou None se não conseguir analisar.
    """
    if not text or len(text.strip()) < 5:
        return {'sentiment': 'neutral', 'reason': 'mensagem muito curta'}

    # 1. Tenta Gemini
    if api_key:
        result = _try_gemini(text, api_key)
        if result:
            return result

    # 2. Fallback por palavras-chave
    return _keyword_fallback(text)


def _try_gemini(text: str, api_key: str) -> dict | None:
    try:
        payload = {
            "contents": [{"parts": [{"text": PROMPT.format(text=text[:500])}]}],
            "generationConfig": {"temperature": 0, "maxOutputTokens": 200},
        }
        resp = requests.post(
            GEMINI_URL,
            headers={"X-goog-api-key": api_key, "Content-Type": "application/json"},
            json=payload,
            timeout=10,
        )

        if resp.status_code in (429, 503):
            return None   # Rate limit → usa fallback

        resp.raise_for_status()
        raw = resp.json()["candidates"][0]["content"]["parts"][0]["text"].strip()

        # Remove markdown ```json ... ```
        raw = re.sub(r'^```(?:json)?\s*', '', raw, flags=re.MULTILINE)
        raw = re.sub(r'```\s*$', '', raw, flags=re.MULTILINE)

        obj = json.loads(raw)
        s = obj.get('sentiment', 'neutral').lower()
        if s not in ('positive', 'negative', 'neutral'):
            s = 'neutral'
        return {'sentiment': s, 'reason': str(obj.get('reason', ''))[:200]}

    except Exception as e:
        logger.debug(f"Gemini falhou: {e}")
        return None


def _keyword_fallback(text: str) -> dict:
    low = text.lower()
    pos = sum(1 for w in POSITIVE_WORDS if w in low)
    neg = sum(1 for w in NEGATIVE_WORDS if w in low)

    if neg > pos:
        return {'sentiment': 'negative', 'reason': 'palavras negativas detectadas'}
    elif pos > neg:
        return {'sentiment': 'positive', 'reason': 'palavras positivas detectadas'}
    return {'sentiment': 'neutral', 'reason': 'sem indicadores claros'}
